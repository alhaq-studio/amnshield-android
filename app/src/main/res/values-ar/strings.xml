    <string name="premium_features_subtitle">Unlock App Blocker, Focus Mode, Reel Blocker, Anti-Uninstall protection, and advanced digital wellbeing tools.</string>
    <string name="premium_features_includes">يشمل الاشتراك المميز:</string>
    <string name="premium_benefit_app_blocker">- App Blocker - Block distracting apps by category with auto-block, cheat hours, and custom warnings</string>
    <string name="premium_benefit_anti_uninstall">- Anti-Uninstall Protection - Password or time-based protection against uninstalling protected apps</string>
    <string name="premium_benefit_priority_support">- App Governance - Better control over protected apps and access integrity</string>
    <string name="premium_benefit_app_guard">- Smart App Guard - Detects common bypass behavior and helps keep protection active</string>
    <string name="premium_benefit_view_blocker">- Reel Blocker - Limit endless scrolling on Instagram Reels, YouTube Shorts, and TikTok videos</string>
    <string name="premium_benefit_focus_mode">- Focus Mode - Time-boxed app blocking with productivity tracking and session history</string>
    <string name="premium_benefit_reports">- Enhanced Statistics - Comprehensive blocking reports, trends, and productivity insights</string>
    <string name="premium_benefit_privacy">- Privacy First - Local processing, no tracking, and no external analytics</string>
    <string name="premium_benefit_future">- Future Features - Priority access to upcoming wellbeing automations</string>

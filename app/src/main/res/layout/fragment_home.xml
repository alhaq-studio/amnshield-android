<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:clipToPadding="false"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/padding_normal"
        android:paddingTop="@dimen/spacing_small"
        android:paddingBottom="@dimen/spacing_large">

        <!-- Welcome Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_welcome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_normal"
            app:cardBackgroundColor="?attr/colorPrimaryContainer"
            app:cardCornerRadius="@dimen/card_corner_radius_large"
            app:cardElevation="@dimen/card_elevation_high"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:minHeight="132dp"
                android:padding="@dimen/padding_large">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/TextAppearance.Material3.HeadlineSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/welcome_to_deenshield"
                        android:textColor="?attr/colorOnPrimaryContainer"
                        android:textStyle="bold" />

                    <TextView
                        style="@style/TextAppearance.Material3.BodyMedium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_small"
                        android:text="@string/protect_your_digital_wellbeing"
                        android:textColor="?attr/colorOnPrimaryContainer" />
                </LinearLayout>

                <ImageView
                    android:layout_width="@dimen/icon_size_xlarge"
                    android:layout_height="@dimen/icon_size_xlarge"
                    android:layout_marginStart="@dimen/spacing_normal"
                    android:src="@drawable/ic_shield"
                    app:tint="?attr/colorOnPrimaryContainer"
                    android:contentDescription="@null" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_dismiss_welcome"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="@dimen/spacing_small"
                    android:contentDescription="@string/hide_welcome_card"
                    app:icon="@drawable/baseline_close_24"
                    app:iconTint="?attr/colorOnPrimaryContainer" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Quick Actions Title -->
        <TextView
            android:id="@+id/txt_quick_actions"
            style="@style/TextAppearance.Material3.TitleMedium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_medium"
            android:layout_marginBottom="@dimen/spacing_medium"
            android:text="@string/quick_actions"
            android:textStyle="bold" />

        <!-- Grid Row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="@dimen/spacing_medium">

            <!-- App Blocker Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_app_blocker"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/spacing_small"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="@dimen/card_corner_radius_normal"
                app:cardElevation="@dimen/card_elevation_high"
                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                app:strokeColor="?attr/colorOutlineVariant"
                app:strokeWidth="1dp"
                app:rippleColor="?attr/colorPrimary">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:minHeight="148dp"
                    android:padding="@dimen/padding_normal">

                    <ImageView
                        android:layout_width="@dimen/icon_size_large"
                        android:layout_height="@dimen/icon_size_large"
                        android:layout_marginBottom="@dimen/spacing_small"
                        android:src="@drawable/baseline_lock_24"
                        android:tint="?attr/colorPrimary" />

                    <TextView
                        style="@style/TextAppearance.Material3.TitleSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/app_blocker"
                        android:textAlignment="center"
                        android:textStyle="bold" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_app_blocker_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_small"
                        android:text="@string/off"
                        app:chipBackgroundColor="?attr/colorErrorContainer"
                        app:chipIcon="@drawable/baseline_stop_24"
                        app:chipIconTint="?attr/colorOnErrorContainer"
                        app:chipStrokeWidth="0dp"
                        app:chipMinHeight="32dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Reel Blocker Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_reel_blocker"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_small"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="@dimen/card_corner_radius_normal"
                app:cardElevation="@dimen/card_elevation_high"
                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                app:strokeColor="?attr/colorOutlineVariant"
                app:strokeWidth="1dp"
                app:rippleColor="?attr/colorPrimary">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:minHeight="148dp"
                    android:padding="@dimen/padding_normal">

                    <ImageView
                        android:layout_width="@dimen/icon_size_large"
                        android:layout_height="@dimen/icon_size_large"
                        android:layout_marginBottom="@dimen/spacing_small"
                        android:src="@drawable/ic_reels_blocker"
                        android:tint="?attr/colorPrimary" />

                    <TextView
                        style="@style/TextAppearance.Material3.TitleSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/reel_blocker"
                        android:textAlignment="center"
                        android:textStyle="bold" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_reel_blocker_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_small"
                        android:text="@string/off"
                        app:chipBackgroundColor="?attr/colorErrorContainer"
                        app:chipIcon="@drawable/baseline_stop_24"
                        app:chipIconTint="?attr/colorOnErrorContainer"
                        app:chipStrokeWidth="0dp"
                        app:chipMinHeight="32dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Grid Row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="@dimen/spacing_medium">

            <!-- Focus Mode Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_focus_mode"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/spacing_small"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="@dimen/card_corner_radius_normal"
                app:cardElevation="@dimen/card_elevation_high"
                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                app:strokeColor="?attr/colorOutlineVariant"
                app:strokeWidth="1dp"
                app:rippleColor="?attr/colorPrimary">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:minHeight="148dp"
                    android:padding="@dimen/padding_normal">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:layout_width="@dimen/icon_size_large"
                        android:layout_height="@dimen/icon_size_large"
                        android:layout_marginBottom="@dimen/spacing_small"
                        android:contentDescription="@string/stats"
                        android:src="@drawable/ic_focus_mode"
                        android:tint="?attr/colorPrimary"
                        app:shapeAppearance="@style/ShapeAppearance.Material3.Corner.Full" />

                    <TextView
                        style="@style/TextAppearance.Material3.TitleSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/focus_mode"
                        android:textAlignment="center"
                        android:textStyle="bold" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_focus_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_small"
                        android:text="@string/off"
                        app:chipBackgroundColor="?attr/colorErrorContainer"
                        app:chipIcon="@drawable/baseline_stop_24"
                        app:chipIconTint="?attr/colorOnErrorContainer"
                        app:chipStrokeWidth="0dp"
                        app:chipMinHeight="32dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Keyword Blocker Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_keyword_blocker"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_small"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="@dimen/card_corner_radius_normal"
                app:cardElevation="@dimen/card_elevation_high"
                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                app:strokeColor="?attr/colorOutlineVariant"
                app:strokeWidth="1dp"
                app:rippleColor="?attr/colorPrimary">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:minHeight="148dp"
                    android:padding="@dimen/padding_normal">

                    <ImageView
                        android:layout_width="@dimen/icon_size_large"
                        android:layout_height="@dimen/icon_size_large"
                        android:layout_marginBottom="@dimen/spacing_small"
                        android:src="@drawable/ic_keyword_blocker"
                        android:tint="?attr/colorPrimary" />

                    <TextView
                        style="@style/TextAppearance.Material3.TitleSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/keyword_blocker"
                        android:textAlignment="center"
                        android:textStyle="bold" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_keyword_blocker_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_small"
                        android:text="@string/off"
                        app:chipBackgroundColor="?attr/colorErrorContainer"
                        app:chipIcon="@drawable/baseline_stop_24"
                        app:chipIconTint="?attr/colorOnErrorContainer"
                        app:chipStrokeWidth="0dp"
                        app:chipMinHeight="32dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Grid Row 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="@dimen/spacing_medium">

            <!-- Usage Tracker Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_usage_tracker"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/spacing_small"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="@dimen/card_corner_radius_normal"
                app:cardElevation="@dimen/card_elevation_high"
                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                app:strokeColor="?attr/colorOutlineVariant"
                app:strokeWidth="1dp"
                app:rippleColor="?attr/colorPrimary">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:minHeight="148dp"
                    android:padding="@dimen/padding_normal">

                    <ImageView
                        android:layout_width="@dimen/icon_size_large"
                        android:layout_height="@dimen/icon_size_large"
                        android:layout_marginBottom="@dimen/spacing_small"
                        android:src="@drawable/ic_deenshield_stats"
                        android:tint="?attr/colorPrimary" />

                    <TextView
                        style="@style/TextAppearance.Material3.TitleSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/usage_tracker"
                        android:textAlignment="center"
                        android:textStyle="bold" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_usage_tracker_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_small"
                        android:text="@string/off"
                        app:chipBackgroundColor="?attr/colorErrorContainer"
                        app:chipIcon="@drawable/baseline_stop_24"
                        app:chipIconTint="?attr/colorOnErrorContainer"
                        app:chipStrokeWidth="0dp"
                        app:chipMinHeight="32dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Anti-Uninstall Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_anti_uninstall"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_small"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="@dimen/card_corner_radius_normal"
                app:cardElevation="@dimen/card_elevation_high"
                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                app:strokeColor="?attr/colorOutlineVariant"
                app:strokeWidth="1dp"
                app:rippleColor="?attr/colorPrimary">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:minHeight="148dp"
                    android:padding="@dimen/padding_normal">

                    <ImageView
                        android:layout_width="@dimen/icon_size_large"
                        android:layout_height="@dimen/icon_size_large"
                        android:layout_marginBottom="@dimen/spacing_small"
                        android:src="@drawable/ic_app_protection"
                        android:tint="?attr/colorPrimary" />

                    <TextView
                        style="@style/TextAppearance.Material3.TitleSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/anti_uninstall"
                        android:textAlignment="center"
                        android:textStyle="bold" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_anti_uninstall_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_small"
                        android:text="@string/off"
                        app:chipBackgroundColor="?attr/colorErrorContainer"
                        app:chipIcon="@drawable/baseline_stop_24"
                        app:chipIconTint="?attr/colorOnErrorContainer"
                        app:chipStrokeWidth="0dp"
                        app:chipMinHeight="32dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Grid Row 4 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="@dimen/spacing_medium">

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/spacing_small" />

            <!-- Premium Features Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_additional_features"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_small"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="@dimen/card_corner_radius_normal"
                app:cardElevation="@dimen/card_elevation_high"
                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                app:strokeColor="?attr/colorOutlineVariant"
                app:strokeWidth="1dp"
                app:rippleColor="?attr/colorPrimary">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:minHeight="148dp"
                    android:padding="@dimen/padding_normal">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:layout_width="@dimen/icon_size_large"
                        android:layout_height="@dimen/icon_size_large"
                        android:layout_marginBottom="@dimen/spacing_small"
                        android:contentDescription="@string/premium_nav_upgrade"
                        android:src="@drawable/ic_premium"
                        android:tint="?attr/colorPrimary"
                        app:shapeAppearance="@style/ShapeAppearance.Material3.Corner.Full" />

                    <TextView
                        style="@style/TextAppearance.Material3.TitleSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/premium_card_title"
                        android:textAlignment="center"
                        android:textStyle="bold" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_additional_features_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_small"
                        android:text="@string/off"
                        app:chipBackgroundColor="?attr/colorErrorContainer"
                        app:chipIcon="@drawable/baseline_stop_24"
                        app:chipIconTint="?attr/colorOnErrorContainer"
                        app:chipStrokeWidth="0dp"
                        app:chipMinHeight="32dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>



    </LinearLayout>
</ScrollView>


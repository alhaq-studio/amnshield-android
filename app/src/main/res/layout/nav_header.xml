<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="200dp"
    android:background="?attr/colorPrimaryContainer"
    android:orientation="vertical"
    android:padding="@dimen/padding_large"
    android:gravity="bottom">

    <ImageView
        android:id="@+id/nav_header_profile_image"
        android:layout_width="@dimen/avatar_size_xlarge"
        android:layout_height="@dimen/avatar_size_xlarge"
        android:layout_marginBottom="@dimen/spacing_medium"
    android:contentDescription="@string/profile_image"
    android:scaleType="centerCrop"
    android:src="@drawable/ic_shield" />

    <TextView
        android:id="@+id/nav_header_username"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/guest_user"
        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
        android:textColor="?attr/colorOnPrimaryContainer"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/nav_header_email"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/not_signed_in"
        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
        android:textColor="?attr/colorOnPrimaryContainer" />

</LinearLayout>

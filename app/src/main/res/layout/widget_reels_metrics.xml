<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_bg_reels"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_card_background"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Header Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/baseline_play_circle_24"
            android:tint="#F43F5E" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="REELS &amp; SHORTS"
            android:textColor="#9CA3AF"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txt_reels_status_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/widget_chip_background"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="ACTIVE 🟢"
            android:textColor="#34D399"
            android:textSize="10sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/refresh_reels_stats"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginStart="8dp"
            android:contentDescription="Refresh"
            android:src="@drawable/baseline_refresh_24"
            android:tint="#10B981" />
    </LinearLayout>

    <!-- Reels Scrolled Count -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txt_reels_scrolled_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 Reels"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txt_reels_limit_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Limit: 100 • 0% Used"
            android:textColor="#9CA3AF"
            android:textSize="12sp" />
    </LinearLayout>
</LinearLayout>

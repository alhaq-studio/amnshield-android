<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:fitsSystemWindows="true"
    android:clipToPadding="false"
    tools:context=".ui.activity.RemindersActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/padding_normal">

        <TextView
            style="@style/TextAppearance.Material3.HeadlineSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_large"
            android:text="Notifications &amp; Reminders"
            android:textStyle="bold" />

        <!-- Daily Reports Section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_normal"
            app:cardCornerRadius="@dimen/card_corner_radius_large"
            app:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_normal">

                <TextView
                    style="@style/TextAppearance.Material3.TitleMedium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊 Daily Reports"
                    android:textStyle="bold" />

                <TextView
                    style="@style/TextAppearance.Material3.BodyMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_tiny"
                    android:layout_marginBottom="@dimen/spacing_medium"
                    android:text="Receive daily summaries of your blocking activity"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/daily_report_switch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Enable daily reports" />

                <LinearLayout
                    android:id="@+id/report_time_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_medium"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        style="@style/TextAppearance.Material3.BodySmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Report time" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/report_time_button"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_tiny"
                        android:text="20:00 (8:00 PM)"
                        app:icon="@drawable/baseline_date_range_24" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Focus Reminders Section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_normal"
            app:cardCornerRadius="@dimen/card_corner_radius_large"
            app:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_normal">

                <TextView
                    style="@style/TextAppearance.Material3.TitleMedium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏱️ Focus Reminders"
                    android:textStyle="bold" />

                <TextView
                    style="@style/TextAppearance.Material3.BodyMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_tiny"
                    android:layout_marginBottom="@dimen/spacing_medium"
                    android:text="Get reminded to start focus mode sessions"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/focus_reminder_switch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Enable focus reminders" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Achievement Notifications Section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_normal"
            app:cardCornerRadius="@dimen/card_corner_radius_large"
            app:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_normal">

                <TextView
                    style="@style/TextAppearance.Material3.TitleMedium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎉 Achievements"
                    android:textStyle="bold" />

                <TextView
                    style="@style/TextAppearance.Material3.BodyMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_tiny"
                    android:layout_marginBottom="@dimen/spacing_medium"
                    android:text="Celebrate your productivity milestones"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/achievement_switch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Enable achievement notifications" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Test Notification Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/test_notification_button"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_large"
            android:text="Test Daily Report Notification"
            app:icon="@drawable/baseline_info_24" />

    </LinearLayout>
</ScrollView>

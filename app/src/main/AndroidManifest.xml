<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission
        android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"/>
    <uses-permission android:name="android.permission.INTERNET" />

    <permission
        android:name="com.alhaq.amnshield.permission.BIND_API"
        android:protectionLevel="signature" />

    <application
        android:name=".AmnShield"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:hardwareAccelerated="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AmnShield"
        tools:targetApi="34">
        <activity
            android:name=".ui.activity.ShortcutActivity"
            android:excludeFromRecents="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.AmnShield.TransparentDialog"
            android:exported="false" />
        <activity
            android:name=".ui.activity.WarningActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:launchMode="singleTask" />
        
        <activity
            android:name=".ui.activity.AntiUninstallPasswordActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:launchMode="singleTask" />
        <activity
            android:name=".ui.activity.FragmentActivity"
            android:exported="false" />


        <activity
            android:name=".ui.activity.ManageKeywordsActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activity.SelectAppsActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activity.RemindersActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activity.NotificationsActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activity.CrashRecoveryActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activity.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
        <activity
            android:name=".ui.activity.LauncherActivity"
            android:exported="true"
            android:launchMode="singleTask" />

        <service
            android:name=".services.AmnShieldAccessibilityService"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>

            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/amnshield_service_config" />
        </service>

        <receiver
            android:name=".receivers.AdminReceiver"
            android:description="@string/admin_permission_desc"
            android:exported="true"
            android:permission="android.permission.BIND_DEVICE_ADMIN">
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>

            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin_receiver_info" />
        </receiver>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <meta-data android:name="android.app.shortcuts"
            android:resource="@xml/shortcuts" />






        <!-- BroadcastReceiver for daily report notifications -->
        <receiver
            android:name=".ui.activity.DailyReportReceiver"
            android:exported="false"
            android:enabled="true" />

        <!-- BroadcastReceiver for auto-blocking newly installed apps -->
        <receiver
            android:name=".receivers.AppInstallReceiver"
            android:exported="true"
            android:enabled="true">
            <intent-filter>
                <action android:name="android.intent.action.PACKAGE_ADDED" />
                <data android:scheme="package" />
            </intent-filter>
        </receiver>

        <!-- API Bound Service for Guardian & paired client apps -->
        <service
            android:name=".api.AmnShieldApiService"
            android:exported="true"
            android:permission="com.alhaq.amnshield.permission.BIND_API">
            <intent-filter>
                <action android:name="com.alhaq.amnshield.api.BIND" />
            </intent-filter>
        </service>

        <!-- API Permission Dialog Activity -->
        <activity
            android:name=".api.ApiPermissionActivity"
            android:exported="true"
            android:theme="@style/Theme.AmnShield.TransparentDialog">
            <intent-filter>
                <action android:name="com.alhaq.amnshield.api.REQUEST_PERMISSION" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Home Screen Widgets -->
        <receiver
            android:name=".ui.widgets.ScreentimeWidgetProvider"
            android:exported="true"
            android:label="Screen Time &amp; App Usage">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name=".amnshield.screentime.WIDGET_REFRESH" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_screentime_metadata" />
        </receiver>

        <receiver
            android:name=".ui.widgets.ReelsMetricsWidgetProvider"
            android:exported="true"
            android:label="Reels &amp; Shorts Metrics">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.alhaq.amnshield.reels.WIDGET_REFRESH" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_reels_metrics_metadata" />
        </receiver>

        <receiver
            android:name=".ui.widgets.QuickFocusWidgetProvider"
            android:exported="true"
            android:label="Quick Focus Space">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.alhaq.amnshield.focus.START_15" />
                <action android:name="com.alhaq.amnshield.focus.START_30" />
                <action android:name="com.alhaq.amnshield.focus.START_60" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_quick_focus_metadata" />
        </receiver>

        <receiver
            android:name=".ui.widgets.BreathingWidgetProvider"
            android:exported="true"
            android:label="Mindful Breathing Space">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.alhaq.amnshield.breathing.START" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_breathing_metadata" />
        </receiver>

    </application>

</manifest>